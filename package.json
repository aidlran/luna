{
  "name": "luna-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Luna app suite monorepo",
  "homepage": "https://github.com/aidlran/luna#readme",
  "bugs": "https://github.com/aidlran/luna/issues",
  "repository": "github:aidlran/luna",
  "license": "AGPL-3.0-only",
  "author": "Aidan Loughran",
  "type": "module",
  "bin": {
    "luna-note": "apps/note/src/cli.mjs",
    "luna-pass": "apps/pass/src/cli.mjs"
  },
  "workspaces": [
    "apps/*",
    "lib/*"
  ],
  "scripts": {
    "build": "npm run build -w lib/astrobase",
    "ci": "conc npm:check npm:lint npm:test",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-solid": "^0.14.5",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "prettier-plugin-jsdoc": "^1.8.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  }
}
